# This file is generated by the release workflow from packaging/homebrew/veld.rb.tmpl.
# Do not edit it directly in the homebrew-tap repo — edit the template and re-release.
class Veld < Formula
  desc "Zero-trust mesh VPN daemon and CLI"
  homepage "https://veld.io"
  license "MIT"
  version "__VERSION__"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/veldmesh/veld/releases/download/v#{version}/veld-v#{version}-darwin_arm64.tar.gz"
      sha256 "__SHA_DARWIN_ARM64__"
    else
      url "https://github.com/veldmesh/veld/releases/download/v#{version}/veld-v#{version}-darwin_amd64.tar.gz"
      sha256 "__SHA_DARWIN_AMD64__"
    end
  end

  on_linux do
    if Hardware::CPU.arm? && Hardware::CPU.is_64_bit?
      url "https://github.com/veldmesh/veld/releases/download/v#{version}/veld-v#{version}-linux_arm64.tar.gz"
      sha256 "__SHA_LINUX_ARM64__"
    else
      url "https://github.com/veldmesh/veld/releases/download/v#{version}/veld-v#{version}-linux_amd64.tar.gz"
      sha256 "__SHA_LINUX_AMD64__"
    end
  end

  def install
    bin.install "veld"
    bin.install "veld-daemon"
    bin.install "veld-coord"
  end

  service do
    run [opt_bin/"veld-daemon", "--config", etc/"veld/config.toml"]
    keep_alive true
    log_path   var/"log/veld-daemon.log"
    error_log_path var/"log/veld-daemon.log"
  end

  test do
    assert_equal "v#{version}", shell_output("#{bin}/veld version").strip
  end
end
